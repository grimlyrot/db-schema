model WhitepageArtifact {
  id            String   @id @default(cuid())
  pwaId         String   @map("pwa_id")
  correlationId String   @map("correlation_id")
  playUrl       String   @map("play_url")
  title         String
  description   String
  iconUrl       String   @map("icon_url")
  screenshots   String[]
  createdAt     DateTime @default(now())
  pwa           Pwa      @relation(fields: [pwaId], references: [id], onDelete: Cascade)

  @@index([pwaId])
  @@map("whitepage_artifacts")
}

model CloakSettings {
  id                       String       @id @default(cuid())
  androidOnly              Boolean      @default(false) @map("android_only")
  allowedOS                AllowedOS    @default(ANDROID_ONLY) @map("allowed_os")
  geoFilterMode            GeoFilterMode @default(OFF) @map("geo_filter_mode")
  geoCountries             Country[]    @default([]) @map("geo_countries")
  blockVpnTorHosting       Boolean      @default(false) @map("block_vpn_tor_hosting")
  blockProxy               Boolean      @default(false) @map("block_proxy")
  trafficbackForAll        Boolean      @default(false) @map("trafficback_for_all")
  trafficbackForNotAndroid Boolean      @default(false) @map("trafficback_for_not_android")
  pixelAsImg               Boolean      @default(false) @map("pixel_as_img")
  pixelInWhitePage         Boolean      @default(false) @map("pixel_in_white_page")
  redirectType             RedirectType @default(CUSTOM) @map("redirect_type")
  whitePageUrl             String?      @map("white_page_url")
  generatedWhitepage       Json?        @map("generated_whitepage")
  pwaId                    String       @unique @map("pwa_id")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  pwa                      Pwa          @relation(fields: [pwaId], references: [id], onDelete: Cascade)
}
